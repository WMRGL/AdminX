<div class="modal fade" id="centeredModalSuccess" tabindex="-1" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">External Clinician</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
          
            <div class="modal-body m-3" id="clinicianModalBody">

                <div id="clinicianSearchBlock">
                    <form id="frmSearchClinician" onsubmit="event.preventDefault(); SearchClinicians();" class="row row-cols-md-auto align-items-center">
                        <div class="col-12"><label class="form-label" for="inlineFormInputName2">First Name</label><input type="text" class="form-control mb-2 me-sm-2" id="inlineFormInputName2" name="firstNameSearch"></div>
                        <div class="col-12"><label class="form-label" for="inlineFormInputName1">Surname</label><input type="text" class="form-control mb-2 me-sm-2" id="inlineFormInputName1" name="lastNameSearch"></div>

                        <div class="col-12"><div class="form-check mb-1 me-sm-2"><input type="checkbox" class="form-check-input" id="chkOnlyCurrent"><label class="form-check-label" for="chkOnlyCurrent">Show Only Current</label></div></div>
                        <div class="col-12"><div class="form-check mb-1 me-sm-2"><input type="checkbox" class="form-check-input" id="chkOnlyGP"><label class="form-check-label" for="chkOnlyGP">Show Only GPs</label></div></div>
                        <div class="col-12"><div class="form-check mb-1 me-sm-2"><input type="checkbox" class="form-check-input" id="chkOnlyNonGP"><label class="form-check-label" for="chkOnlyNonGP">Show Only Non-GPs</label></div></div>

                        <div class="col-12 mt-2 w-100">
                            <button type="button" class="btn btn-success" onclick="SearchClinicians()">Search</button>
                            <button type="button" class="btn btn-outline-primary float-end" onclick="ToggleClinicianViews('add')">Add New External Clinician</button>
                        </div>
                    </form>

                    <div class="mt-4 table-responsive" style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-sm table-striped table-hover" id="tblClinicianResults" style="display:none;">
                            <thead class="table-dark"><tr><th>Code</th><th>Name</th><th>Facility</th><th>Role</th><th>Action</th></tr></thead>
                            <tbody id="tblClinicianResultsBody"></tbody>
                        </table>
                    </div>
                </div>

                <div id="clinicianAddBlock" style="display:none;">
                    <form id="frmAddClinician" onsubmit="event.preventDefault(); SubmitNewClinician();">
                        <div class="row">
                            <div class="col-md-4 mb-2">
                                <label class="form-label">Clinician Code</label>
                                <input type="text" id="addClinCode" class="form-control"></div>
                            <div class="col-md-2 mb-2">
                                <label class="form-label">Title</label>
                                <select id="addTitle" class="form-select" required>
                                    <option value="">Select...</option>
                                </select>
                            </div>
                            <div class="col-md-3 mb-2"><label class="form-label">First Name</label><input type="text" id="addFirstName" class="form-control" required></div>
                            <div class="col-md-3 mb-2"><label class="form-label">Last Name</label><input type="text" id="addLastName" class="form-control" required></div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-2"><label class="form-label">Speciality</label><input type="text" id="addSpeciality" class="form-control"></div>
                            <div class="col-md-4 mb-2"><label class="form-label">Position</label><input type="text" id="addPosition" class="form-control"></div>
                            <div class="col-md-4 mb-2">
                                <label class="form-label">Is GP?</label>
                                <select id="addIsGP" class="form-select">
                                    <option value="0">No</option>
                                    <option value="-1">Yes</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Facility Search</label>
                                <input type="text" id="addFacilitySearch" class="form-control mb-2" placeholder="Type at least 2 characters to search facilities..." onkeyup="DebounceFacilitySearch()">

                                <select id="addFacility" class="form-select" size="4" required>
                                    <option value="">Please type above to search...</option>
                                </select>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                            <button type="button" class="btn btn-secondary" onclick="ToggleClinicianViews('search')">Back to Search</button>
                            <button type="submit" class="btn btn-success" id="btnSaveNewClinician">Save & Select Clinician</button>
                        </div>
                    </form>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
