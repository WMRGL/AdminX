    //         clockStart = Date.parse(document.getElementById("ClockStartDateC").value);
    //         clockStop = Date.parse(document.getElementById("ClockStopDateC").value);
    //         clockAgeTotal = document.getElementById("clockageC");
    //     }
        
    //     var clockAge;
    //     var today = new Date();        


    //     if (isNaN(clockStop)) 
    //     {   
    //         clockAge = today - clockStart;            
    //     }
    //     else 
    //     {   
    //         clockAge = clockStop - clockStart;
    //     }
    //     var clockAgeDays = ((clockAge / 1000) / 3600) / 24;
    //     clockAgeTotal.value = Math.floor(clockAgeDays) + " days (" + Math.ceil(clockAgeDays / 7) + " weeks)";
    // }

            function CalculateClockAge()
        {
            var clockStartEl = document.getElementById("ClockStartDate");
            var clockStopEl = document.getElementById("ClockStopDate");
            var clockAgeTotal = document.getElementById("clockage");

            if (!clockStartEl || !clockStopEl || !clockAgeTotal) return;

            var clockStart = Date.parse(clockStartEl.value);
            var clockStop = Date.parse(clockStopEl.value);

            var clockAge;
            var today = new Date();

            if (isNaN(clockStart)) {
                clockAgeTotal.value = "";
                return;
            }

            if (isNaN(clockStop))
            {
                clockAge = today - clockStart;
            }
            else
            {
                clockAge = clockStop - clockStart;
            }

            var clockAgeDays = ((clockAge / 1000) / 3600) / 24;
            clockAgeTotal.value = Math.floor(clockAgeDays) + " days (" + Math.ceil(clockAgeDays / 7) + " weeks)";
        }

        function SetToGP()
        {
            var _referrerList = document.getElementById("referrerCode");

            const newCode = "@Model.patient.GP_Code";

            _referrerList.value = newCode;

            if (_referrerList.choices) {
                _referrerList.choices.setChoiceByValue(newCode);
            }

            if (typeof updateFacility === "function") {
                updateFacility();
            }
        }

      

    refCode.addEventListener("change", updateFacility);

    updateFacility();
    CalculateClockAge();


    if (document.getElementById("referrerCode").value.length > 8)
    {
    window.alert("The selected referrer code is too long. Please select a different GP.");
    }

           

</script>


