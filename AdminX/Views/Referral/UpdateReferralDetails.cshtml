@section Scripts {
<script src="~/js/clinicianSearch.js"></script>
<script src="~/js/referral.js"></script>
        
<script>

      
    var refCode;
    var facilityDetails;
   
    // if("@Model.referral.PATHWAY".startsWith("General"))
    // {
    //     refCode = document.getElementById("referrerCodeG");
    //     facilityDetails = document.getElementById("facilityFullDetailsG");
    //     SetClinicianTarget("referrerCodeG");
    // }
    // else
    // {
    //     refCode = document.getElementById("referrerCodeC");
    //     facilityDetails = document.getElementById("facilityFullDetailsC");   
    //     SetClinicianTarget("referrerCodeC");

    // }

        var refCode = document.getElementById("referrerCode");
        var facilityDetails = document.getElementById("facilityFullDetails");

        SetClinicianTarget("referrerCode");

        // Show/Hide Cancer block based on dropdown
        function ShowCancerStuff() {
            var cStuff = document.getElementById("cancerStuff");
            var pathway = document.getElementById("ddlPathway").value;
            if (pathway && pathway.includes("Cancer")) {
                cStuff.hidden = false;
            } else {
                cStuff.hidden = true;
            }
        }

        document.getElementById("ddlPathway").addEventListener("change", ShowCancerStuff);
        window.addEventListener("load", ShowCancerStuff);

            // --- Initialise once at page load ---
        var facilityCodeArray = [];
        var facilityNameArray = [];
        var facilityAddressArray = [];
        var facilityCityArray = [];
        var facilityStateArray = [];
        var facilityPostcodeArray = [];
        var referrerCodes = [];
        var facCodeArray = [];

        @foreach (var item in Model.facilities)
        {
                @:facilityCodeArray.push("@item.MasterFacilityCode");
                @:facilityNameArray.push("@item.NAME");
                @:facilityAddressArray.push("@item.ADDRESS");
                @:facilityCityArray.push("@item.CITY");
                @:facilityStateArray.push("@item.STATE");
                @:facilityPostcodeArray.push("@item.ZIP");
        }

        @foreach (var item in Model.referrers)
        {
                @:referrerCodes.push("@item.MasterClinicianCode");
                @:facCodeArray.push("@item.MasterFacilityCode");
        }

           function updateFacility()
        {
            if (!refCode || !facilityDetails) return;

            var selectedCode = refCode.value;

            if (selectedCode === "Self/FamMemb" ) {
                facilityDetails.value = "Not Applicable"; 
                return;
            }

            // Handle GP Selection
            if (selectedCode === "@Model.patient?.GP_Code") {
                let fullDetails = "@Model.GPFacility.NAME" + ", " +
                    "@Model.GPFacility.ADDRESS" + ", " +
                    "@Model.GPFacility.CITY" + ", " +
                    "@Model.GPFacility.STATE" + " " +
                    "@Model.GPFacility.ZIP";

                facilityDetails.value = fullDetails
                    .replace(/&#x27;/g, "'")
                    .replace(/&amp;/g, "&")
                    .replace(/&#xD;/g, "")
                    .replace(/&#xA;/g, "\n");

                return;
            }

            // OPTIMISED SEARCH: Use .indexOf() instead of a slow for...in loop
            var refIndex = referrerCodes.indexOf(selectedCode);

            if (refIndex !== -1) {
                var facCode = facCodeArray[refIndex];
                var facIndex = facilityCodeArray.indexOf(facCode);

                if (facIndex !== -1) {
                    let fullDetails = facilityNameArray[facIndex] + ", " +
                        facilityAddressArray[facIndex] + ", " +
                        facilityCityArray[facIndex] + ", " +
                        facilityStateArray[facIndex] + " " +
                        facilityPostcodeArray[facIndex];

                    facilityDetails.value = fullDetails
                        .replace(/&#x27;/g, "'")
                        .replace(/&amp;/g, "&")
                        .replace(/&#xD;/g, "")
                        .replace(/&#xA;/g, "\n");

                    return;
                }
            }

            facilityDetails.value = "";
        }


    // function CalculateClockAge() 
    // {
    //     var clockStart;
    //     var clockStop;
    //     var clockAgeTotal;

    //     if("@Model.referral.PATHWAY".startsWith("General"))
    //     {
    //         clockStart = Date.parse(document.getElementById("ClockStartDateG").value);
    //         clockStop = Date.parse(document.getElementById("ClockStopDateG").value);
    //         clockAgeTotal = document.getElementById("clockageG");
    //     }
    //     else
